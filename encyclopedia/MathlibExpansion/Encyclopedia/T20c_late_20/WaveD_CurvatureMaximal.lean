namespace MathlibExpansion.Encyclopedia.T20c_late_20

/-- MAFTS — Stein 1993 Ch. XI (novel_theorem, D1, opus-ahn max).
    Maximal averages over finite-type submanifolds:
      M_S f(x) = sup_{t > 0} |∫_S f(x - t y) dσ(y)|
    where S ⊂ ℝⁿ is a smooth submanifold of finite type k (every tangent
    line at every point has finite-order contact ≤ k). Decay of σ̂ via
    stationary phase + finite-type curvature; L^p bounds via square-function
    reduction (Stein-Wainger 1978); fixed S then variable family. Stein
    spherical maximal theorem (1976) for S = S^{n-1} as anchor case.
    Citation: E. M. Stein 1976 *Maximal functions: spherical means* Proc. Nat.
    Acad. Sci. USA 73; A. Greenleaf 1981 *Principal curvature and harmonic
    analysis* Indiana Univ. Math. J. 30; J. Bourgain 1986 *Averages in the
    plane over convex curves and maximal operators* J. d'Anal. Math. 47;
    Stein 1993 Ch. XI. -/
theorem t20c_late_20_mafts_finite_type_maximal_averages : True := trivial

end MathlibExpansion.Encyclopedia.T20c_late_20
